{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "quick-note",
  "version": "0.1.0",
  "identifier": "com.quick-note.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "quick-note",
        "width": 64,
        "height": 64,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "visible": true,
        "x": 0,
        "y": 40
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
